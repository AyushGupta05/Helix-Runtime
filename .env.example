# Civic MCP
CIVIC_URL=https://app.civic.com/hub/mcp?accountId=your-account-id&profile=default
CIVIC_TOKEN=

# Bedrock-first model routing
MODEL_PROVIDER=bedrock
BEDROCK_REGION=us-east-1
BEDROCK_PROFILE=
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Lane to model mappings
BEDROCK_MODEL_TRIAGE=us.amazon.nova-lite-v1:0
BEDROCK_MODEL_BID_FAST=us.amazon.nova-lite-v1:0
BEDROCK_MODEL_BID_DEEP=us.anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_MODEL_TEST_GEN=us.amazon.nova-pro-v1:0
BEDROCK_MODEL_PERF_REASON=us.anthropic.claude-3-7-sonnet-20250219-v1:0

# Optional fallback providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL_TRIAGE=gpt-4.1-mini
OPENAI_MODEL_BID_FAST=gpt-4.1-mini
OPENAI_MODEL_BID_DEEP=gpt-4.1
OPENAI_MODEL_TEST_GEN=gpt-4.1
OPENAI_MODEL_PERF_REASON=gpt-4.1

# Mission defaults
ARBITER_MAX_PARALLEL_BIDDERS=8
ARBITER_MAX_PARALLEL_VALIDATORS=4
ARBITER_MAX_RUNTIME_MINUTES=10
ARBITER_MAX_FILE_CHURN=8
ARBITER_MAX_RECOVERY_ROUNDS=3
ARBITER_REPLAY_MODE=off
